		<servlet-class>hishopping.servlet.MerchantAnalyticsServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>MerchantAnalyticsServlet</servlet-name>
		<url-pattern>/merchant/analytics</url-pattern>
	</servlet-mapping>
	<servlet>
		<servlet-name>AccountRequestServlet</servlet-name>
		<servlet-class>hishopping.servlet.AccountRequestServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>AccountRequestServlet</servlet-name>
		<url-pattern>/accountRequests</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>AccountRequestServlet</servlet-name>
		<url-pattern>/admin/accountRequests</url-pattern>
	</servlet-mapping>
	<servlet>
		<servlet-name>AvatarUploadServlet</servlet-name>
		<servlet-class>hishopping.servlet.AvatarUploadServlet</servlet-class>
		<multipart-config>
			<max-file-size>5242880</max-file-size>
			<max-request-size>6291456</max-request-size>
			<file-size-threshold>1048576</file-size-threshold>
		</multipart-config>
	</servlet>
	<servlet-mapping>
		<servlet-name>AvatarUploadServlet</servlet-name>
		<url-pattern>/avatarUpload</url-pattern>
	</servlet-mapping>
</web-app>

